{
  "name": "x-like-auto-save-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:scheduled": "wrangler dev --test-scheduled",
    "db:init:local": "wrangler d1 execute CF_D1_DATABASE_NAME_REMOVED --local --file=migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute CF_D1_DATABASE_NAME_REMOVED --remote --file=migrations/0001_init.sql",
    "build": "npm run cf-typegen && npm run check && npm run db:init:local",
    "deploy": "npm run build && npm run db:init:remote && wrangler deploy",
    "check": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "grammy": "^1.38.2",
    "hono": "^4.9.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250906.0",
    "typescript": "^5.9.2",
    "wrangler": "^4.20.0"
  }
}
