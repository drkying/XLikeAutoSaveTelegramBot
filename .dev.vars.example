# Local-only template for `wrangler dev`.
# Do not store real secrets in committed files.

# Required: Bot token from BotFather.
TELEGRAM_BOT_TOKEN=__YOUR_TELEGRAM_BOT_TOKEN__

# Optional: Telegram Bot API endpoint. Leave empty to use https://api.telegram.org.
# Set to https://tgbotapi.drkying.com to use the self-hosted Bot API.
TELEGRAM_API_BASE=

# Optional: Telegram chat id for admin alerts.
ADMIN_CHAT_ID=

# Optional: must match Telegram `setWebhook` secret_token if enabled.
WEBHOOK_SECRET=

# Keep false unless you intentionally run on Workers Paid.
WORKERS_PAID_ENABLED=false

# Optional: public host for R2 objects, for example https://media.example.com
R2_PUBLIC_DOMAIN=

# OAuth callback base URL. Replace with your tunnel URL for local OAuth/webhook tests.
APP_BASE_URL=http://localhost:8787
